@page "/review/{reviewId:guid}"
@using WebApi.Models
@using WebApi.Services.Reply
@using System.Net.Http.Json
@using System.Text.Json.Serialization
@inject IReplyService ReplyService
@inject NavigationManager NavigationManager
@inject HttpClient http

<h3>Reply to Review</h3>

    <div class="card my-3">
        <div class="card-body">
            <h5 class="card-title">Review by @ClientName</h5>
            <h6 class="card-subtitle mb-2 text-muted">Sentiment: @Sentiment</h6>
            <p class="card-text">@RawText</p>
        </div>
    </div>

    <div class="card my-3">
        <div class="card-body">
            <h5 class="card-title">Leave a Reply</h5>
            <EditForm Model="@_replyInput" OnValidSubmit="@SubmitReply">
                <DataAnnotationsValidator />
                <ValidationSummary />
                <div class="mb-3">
                    <label class="form-label">Reply</label>
                    <InputTextArea class="form-control" @bind-Value="_replyInput.RawText" />
                </div>
                <button type="submit" class="btn btn-primary">Submit</button>
            </EditForm>
        </div>
    </div>

@code {
    [Parameter]
    public Guid ReviewId { get; set; }

    [SupplyParameterFromQuery]
    public Guid BusinessId { get; set; }

    [SupplyParameterFromQuery]
    public Guid ClientId { get; set; }

    [SupplyParameterFromQuery]
    public string RawText { get; set; } = string.Empty;

    [SupplyParameterFromQuery]
    public string ClientName { get; set; } = string.Empty;

    [SupplyParameterFromQuery]
    public string Sentiment { get; set; } = string.Empty;

    private ReplyInput _replyInput = new();

    protected async override Task OnInitializedAsync()
    {
        try
        {
            var response = await http.PostAsJsonAsync("http://localhost:8000/ai/reply/", new {raw_text = RawText, customer_name = ClientName, sentiment = Sentiment});
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ReplyInput>();
                if (result != null)
                {
                    _replyInput.RawText = result.RawText;
                }
            }
        }
        catch
        {
            _replyInput.RawText = string.Empty;
        }
    }

    private async Task SubmitReply()
    {
        await ReplyService.AddReviewAsync(ReviewId, ClientId, _replyInput.RawText);
        NavigationManager.NavigateTo($"/reviews/{BusinessId}");
    }

    public class ReplyInput
    {
        [JsonPropertyName("reply")]
        public string RawText { get; set; } = string.Empty;
    }

    public class GenerateReply
    {
        public string RawText { get; set; } = string.Empty;
        public string CustomerName { get; set; } = string.Empty;
        public string Sentiment { get; set; } = string.Empty;
    }
}