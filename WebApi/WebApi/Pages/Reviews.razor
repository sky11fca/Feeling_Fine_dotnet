@page "/reviews/{businessId:guid}"
@using WebApi.Models
@using WebApi.Services.Business
@using WebApi.Services.Client
@using WebApi.Services.Reviews
@using WebApi.Services.Reply
@inject IReviewsService ReviewsService
@inject IBusinessService BusinessService
@inject IClientService ClientService
@inject IReplyService ReplyService

@if (_business != null)
{
    <h3>Reviews for @_business.Name</h3>
    <p>@_business.Industry</p>
}
else
{
    <h3>Reviews</h3>
}

<div class="card my-3">
    <div class="card-body">
        <h5 class="card-title">Add a Review</h5>
        <EditForm Model="@_reviewInput" OnValidSubmit="@SubmitReview">
            <DataAnnotationsValidator />
            <ValidationSummary />
            <div class="mb-3">
                <label class="form-label">Rating (1-5)</label>
                <InputNumber class="form-control" @bind-Value="_reviewInput.Rating" />
            </div>
            <div class="mb-3">
                <label class="form-label">Review</label>
                <InputTextArea class="form-control" @bind-Value="_reviewInput.RawText" />
            </div>
            <button type="submit" class="btn btn-primary">Submit</button>
        </EditForm>
    </div>
</div>

@if (_reviewList.Count != 0)
{
    <div class="list-group mt-3">
        @foreach (var review in _reviewList)
        {
            <a href="/review/@review.Id?businessId=@BusinessId&clientId=@review.ClientId&rawText=@Uri.EscapeDataString(review.RawText)&clientName=@Uri.EscapeDataString(_clientNames.TryGetValue(review.ClientId, out var name) ? name : "Unknown")&sentiment=@Uri.EscapeDataString(review.SentimentLabel)" class="list-group-item list-group-item-action">
                <strong>@(_clientNames.TryGetValue(review.ClientId, out var username) ? username : review.Id.ToString())</strong>
                <p>@review.Review / 5.0 (@review.RatingType)</p>
                <p>@review.RawText</p>
                <p>Posted on: @review.SubmittedOn</p>
                <p>The sentiment conveys is: @review.SentimentLabel</p>
                <p>Accuracy: @review.SentimentAccuracy</p>
                @if (_replies.TryGetValue(review.Id, out var reply))
                {
                    <p class="ms-4"><strong>Reply:</strong> @reply.RawText</p>
                }
            </a>
            
        }
    </div>
}
else
{
    <p>No reviews found</p>
}

@code {

    [Parameter]
    public Guid BusinessId { get; set; }

    private List<ReviewDto?> _reviewList = new();
    private BusinessDto? _business;
    private ReviewInput _reviewInput = new();
    private Dictionary<Guid, string> _clientNames = new();
    private Dictionary<Guid, ReplyDto> _replies = new();

    protected async override Task OnInitializedAsync()
    {

        try
        {
            _reviewList = await ReviewsService.GetReviewQuery(BusinessId, string.Empty, string.Empty);
            await FetchClientNames();
            await FetchReplies();
            var business = await BusinessService.GetBusinessQuery(string.Empty, string.Empty);
            _business = business.Find(b => b.Id == BusinessId);
        }
        catch
        {
            _reviewList = new();
        }
    }

    private async Task FetchClientNames()
    {
        foreach (var review in _reviewList)
        {
            if (review != null && !_clientNames.ContainsKey(review.ClientId))
            {
                try
                {
                    var client = await ClientService.FindAsync(review.ClientId);
                    if (client != null)
                    {
                        _clientNames[review.ClientId] = client.Username;
                    }
                }
                catch { }
            }
        }
    }

    private async Task FetchReplies()
    {
        foreach (var review in _reviewList)
        {
            if (review != null && !_replies.ContainsKey(review.Id))
            {
                try
                {
                    var replies = await ReplyService.GetRepliesAsync(review.Id);
                    if (replies != null && replies.Count > 0)
                    {
                        _replies[review.Id] = replies[0];
                    }
                }
                catch { }
            }
        }
    }

    private async Task SubmitReview()
    {
        await ReviewsService.AddReview(BusinessId, _reviewInput.ClientId, _reviewInput.Rating, _reviewInput.RawText, "FeelingFine");
        
        _reviewList = await ReviewsService.GetReviewQuery(BusinessId, string.Empty, string.Empty);
        await FetchReplies();
        _reviewInput = new();
    }

    public class ReviewInput
    {
        public Guid ClientId { get; set; } = Guid.NewGuid();
        public decimal Rating { get; set; }
        public string RawText { get; set; } = string.Empty;
    }
}